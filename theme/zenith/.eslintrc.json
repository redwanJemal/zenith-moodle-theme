{
  "env": {
    "browser": true,
    "es2022": true,
    "amd": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "globals": {
    "M": "readonly",
    "Y": "readonly"
  },
  "rules": {
    "no-console": "warn",
    "no-unused-vars": ["warn", { "args": "none" }],
    "no-undef": "error",
    "semi": ["error", "always"],
    "quotes": ["warn", "single", { "avoidEscape": true }],
    "indent": ["warn", 4],
    "no-trailing-spaces": "warn",
    "eol-last": "warn"
  }
}
