{{!
    @template theme_zenith/customizer/section_typography

    Font family, size, weight, line-height controls.
}}
<div class="z-customizer__section-title">{{#str}}customizer_typography_title, theme_zenith{{/str}}</div>
<p class="z-customizer__section-desc">{{#str}}customizer_typography_desc, theme_zenith{{/str}}</p>

<div class="z-customizer__control-group">
    <label class="z-customizer__label" for="z-cust-font_family">{{#str}}customizer_font_family, theme_zenith{{/str}}</label>
    <select id="z-cust-font_family" data-setting="font_family" class="z-customizer__select">
        <option value="Inter">Inter</option>
        <option value="Roboto">Roboto</option>
        <option value="Open Sans">Open Sans</option>
        <option value="Lato">Lato</option>
        <option value="Nunito">Nunito</option>
        <option value="Source Sans Pro">Source Sans Pro</option>
        <option value="DM Sans">DM Sans</option>
        <option value="IBM Plex Sans">IBM Plex Sans</option>
        <option value="Poppins">Poppins</option>
        <option value="Montserrat">Montserrat</option>
        <option value="system-ui">System Default</option>
    </select>
</div>

<div class="z-customizer__control-group">
    <label class="z-customizer__label" for="z-cust-font_size">
        {{#str}}customizer_font_size, theme_zenith{{/str}}
        <span class="z-customizer__value-display" data-display="font_size">15px</span>
    </label>
    <input type="range" id="z-cust-font_size" data-setting="font_size"
           class="z-customizer__range" min="13" max="18" step="1" value="15">
</div>

<div class="z-customizer__control-group">
    <label class="z-customizer__label" for="z-cust-heading_weight">{{#str}}customizer_heading_weight, theme_zenith{{/str}}</label>
    <select id="z-cust-heading_weight" data-setting="heading_weight" class="z-customizer__select">
        <option value="400">Regular (400)</option>
        <option value="500">Medium (500)</option>
        <option value="600">Semi Bold (600)</option>
        <option value="700">Bold (700)</option>
        <option value="800">Extra Bold (800)</option>
    </select>
</div>

<div class="z-customizer__control-group">
    <label class="z-customizer__label" for="z-cust-body_weight">{{#str}}customizer_body_weight, theme_zenith{{/str}}</label>
    <select id="z-cust-body_weight" data-setting="body_weight" class="z-customizer__select">
        <option value="300">Light (300)</option>
        <option value="400">Regular (400)</option>
        <option value="500">Medium (500)</option>
    </select>
</div>

<div class="z-customizer__control-group">
    <label class="z-customizer__label" for="z-cust-line_height">
        {{#str}}customizer_line_height, theme_zenith{{/str}}
        <span class="z-customizer__value-display" data-display="line_height">1.5</span>
    </label>
    <input type="range" id="z-cust-line_height" data-setting="line_height"
           class="z-customizer__range" min="1.2" max="1.8" step="0.1" value="1.5">
</div>
