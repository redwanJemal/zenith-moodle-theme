{{!
    @template theme_zenith/customizer/section_colors

    8 color pickers with native input + hex text input.
}}
<div class="z-customizer__section-title">{{#str}}customizer_colors_title, theme_zenith{{/str}}</div>
<p class="z-customizer__section-desc">{{#str}}customizer_colors_desc, theme_zenith{{/str}}</p>

<div class="z-customizer__control-group">
    <label class="z-customizer__label" for="z-cust-primary">{{#str}}customizer_primary, theme_zenith{{/str}}</label>
    <div class="z-customizer__color-input">
        <input type="color" id="z-cust-primary" data-setting="primary" class="z-customizer__color-picker">
        <input type="text" data-setting="primary" data-type="hex" class="z-customizer__hex-input"
               maxlength="7" pattern="#[0-9a-fA-F]{6}" aria-label="{{#str}}customizer_hex, theme_zenith{{/str}}">
    </div>
</div>

