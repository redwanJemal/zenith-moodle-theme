{{!
    @template theme_zenith/customizer/panel

    Visual customizer sidebar panel with 6 section tabs.
}}
<div id="z-customizer" class="z-customizer" role="dialog" aria-label="{{#str}}customizer, theme_zenith{{/str}}" aria-hidden="true">
    <div class="z-customizer__backdrop" data-action="customizer-close"></div>
    <div class="z-customizer__panel">
        {{! Header }}
        <div class="z-customizer__header">
            <h2 class="z-customizer__title">{{#str}}customizer, theme_zenith{{/str}}</h2>
            <button class="z-customizer__close" data-action="customizer-close" type="button"
                    aria-label="{{#str}}closebuttontitle, core{{/str}}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" aria-hidden="true">
                    <path d="M18 6L6 18M6 6l12 12"/>
                </svg>
            </button>
        </div>

        {{! Section Tabs }}
        <div class="z-customizer__tabs" role="tablist" aria-label="{{#str}}customizer_sections, theme_zenith{{/str}}">
            <button class="z-customizer__tab z-customizer__tab--active" role="tab"
                    aria-selected="true" aria-controls="z-cust-section-presets"
                    data-section="presets" type="button">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                    <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                </svg>
                <span>{{#str}}customizer_presets, theme_zenith{{/str}}</span>
            </button>
            <button class="z-customizer__tab" role="tab"
                    aria-selected="false" aria-controls="z-cust-section-colors"
                    data-section="colors" type="button">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <circle cx="13.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="10.5" r="2.5"/>
                    <circle cx="8.5" cy="7.5" r="2.5"/><circle cx="6.5" cy="12.5" r="2.5"/>
                    <path d="M12 22c5.52 0 10-4.48 10-10S17.52 2 12 2 2 6.48 2 12c0 1.51.34 2.94.93 4.23.41.9 1.17 1.55 2.14 1.55h1.8c1.54 0 2.38-1.77 1.38-2.9-.65-.73-1.02-1.67-1.02-2.67 0-2.25 2.01-4.08 4.42-3.98 2.21.09 4.01 1.97 4.01 4.18 0 .93-.31 1.78-.81 2.47-.75 1.02.1 2.47 1.33 2.47.73 0 1.48-.29 2.01-.8"/>
                </svg>
                <span>{{#str}}customizer_colors, theme_zenith{{/str}}</span>
            </button>
            <button class="z-customizer__tab" role="tab"
                    aria-selected="false" aria-controls="z-cust-section-typography"
                    data-section="typography" type="button">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M4 7V4h16v3M9 20h6M12 4v16"/>
                </svg>
                <span>{{#str}}customizer_typography, theme_zenith{{/str}}</span>
            </button>
            <button class="z-customizer__tab" role="tab"
                    aria-selected="false" aria-controls="z-cust-section-buttons"
                    data-section="buttons" type="button">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect x="3" y="8" width="18" height="8" rx="3"/>
                    <path d="M9 12h6"/>
                </svg>
                <span>{{#str}}customizer_buttons, theme_zenith{{/str}}</span>
            </button>
            <button class="z-customizer__tab" role="tab"
                    aria-selected="false" aria-controls="z-cust-section-header"
                    data-section="header" type="button">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="6" rx="2"/><path d="M3 13h18M3 17h12"/>
                </svg>
                <span>{{#str}}customizer_header, theme_zenith{{/str}}</span>
            </button>
            <button class="z-customizer__tab" role="tab"
                    aria-selected="false" aria-controls="z-cust-section-footer"
                    data-section="footer" type="button">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect x="3" y="15" width="18" height="6" rx="2"/><path d="M3 7h18M3 11h12"/>
                </svg>
                <span>{{#str}}customizer_footer, theme_zenith{{/str}}</span>
            </button>
        </div>

        {{! Section Content }}
        <div class="z-customizer__content">
            <div id="z-cust-section-presets" class="z-customizer__section z-customizer__section--active"
                 role="tabpanel" aria-labelledby="presets">
                {{> theme_zenith/customizer/section_presets }}
            </div>
            <div id="z-cust-section-colors" class="z-customizer__section"
                 role="tabpanel" aria-labelledby="colors" hidden>
                {{> theme_zenith/customizer/section_colors }}
            </div>
            <div id="z-cust-section-typography" class="z-customizer__section"
                 role="tabpanel" aria-labelledby="typography" hidden>
                {{> theme_zenith/customizer/section_typography }}
            </div>
            <div id="z-cust-section-buttons" class="z-customizer__section"
                 role="tabpanel" aria-labelledby="buttons" hidden>
                {{> theme_zenith/customizer/section_buttons }}
            </div>
            <div id="z-cust-section-header" class="z-customizer__section"
                 role="tabpanel" aria-labelledby="header" hidden>
                {{> theme_zenith/customizer/section_header }}
            </div>
            <div id="z-cust-section-footer" class="z-customizer__section"
                 role="tabpanel" aria-labelledby="footer" hidden>
                {{> theme_zenith/customizer/section_footer }}
            </div>
        </div>

        {{! Footer Actions }}
        <div class="z-customizer__footer">
            <button class="btn btn-outline-secondary btn-sm" data-action="customizer-reset" type="button">
                {{#str}}customizer_reset, theme_zenith{{/str}}
            </button>
            <div class="z-customizer__footer-right">
                <button class="btn btn-outline-secondary btn-sm" data-action="customizer-cancel" type="button">
                    {{#str}}cancel, core{{/str}}
                </button>
                <button class="btn btn-primary btn-sm" data-action="customizer-save" type="button">
                    {{#str}}customizer_save, theme_zenith{{/str}}
                </button>
            </div>
        </div>
    </div>
</div>
